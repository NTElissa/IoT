PORT=5000
NODE_ENV=development

# MongoDB connection string. Use a local instance or MongoDB Atlas.
MONGO_URI=mongodb://127.0.0.1:27017/smart_iv_monitoring

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - frontend origin
CLIENT_URL=http://localhost:5173

# Alert thresholds (percent)
LOW_FLUID_THRESHOLD=10
WARNING_FLUID_THRESHOLD=20
HIGH_FLUID_THRESHOLD=90

# Escalation window in minutes if an alert is not acknowledged
ESCALATION_MINUTES=10

# Simulation tick interval in milliseconds (how often fluid levels update)
SIMULATION_TICK_MS=8000
